# Copier en `.env.local` et remplir. Ne JAMAIS committer les valeurs réelles.
# (`.env.local` est dans .gitignore — vérifié : aucune clé n'est dans le dépôt ni son historique.)

# --- Base de données (PostgreSQL) ---
DATABASE_URL="postgresql://user:password@host:5434/dbname?sslmode=disable"

# --- API France Travail (https://francetravail.io) ---
# Identifiants OAuth2 (client-credentials) à créer sur le portail francetravail.io
FRANCE_TRAVAIL_CLIENT_ID=""
FRANCE_TRAVAIL_CLIENT_SECRET=""

# --- API Adzuna (https://developer.adzuna.com) ---
ADZUNA_APP_ID=""
ADZUNA_APP_KEY=""

# --- Cron (protège la route HTTP /api/cron/collect ; le cron système, lui, lance npm run collect) ---
CRON_SECRET=""

# --- Surveillance : alertes "source cassée" poussées vers ce webhook (Discord ou compatible {content}) ---
# Optionnel : sans cette variable, les alertes restent dans collect.log. Cf. deploy/README.md.
ALERT_WEBHOOK_URL=""

# --- Notifications utilisateur (Phase 2) ---
# RESEND_API_KEY=""
