# Copier en `.env.local` et remplir. Ne JAMAIS committer les valeurs réelles.

# --- Base de données (Neon / PostgreSQL) ---
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- API France Travail (https://francetravail.io) ---
# Identifiants OAuth2 (client-credentials) à créer sur le portail francetravail.io
FRANCE_TRAVAIL_CLIENT_ID=""
FRANCE_TRAVAIL_CLIENT_SECRET=""

# --- Cron (protège la route de polling déclenchée par Vercel Cron) ---
CRON_SECRET=""

# --- Notifications (Phase 2) ---
# DISCORD_WEBHOOK_URL=""
# RESEND_API_KEY=""
